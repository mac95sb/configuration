{
  "agent": {
    "default_model": {
      "provider": "openai-subscribed",
      "model": "gpt-5.6-terra",
      "enable_thinking": true,
      "effort": "medium",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "format_on_save": "on",

  "agent_servers": {
    "claude-acp": {
      "default_config_options": {
        "mode": "auto",
        "model": "claude-fable-5",
      },
      "type": "registry",
    },
  },

  "auto_install_extensions": {
    "comment": true,
    "git-firefly": true,
    "html": true,
    "make": true,
    "markdown-oxide": true,
    "package-swift-lsp": true,
    "pbxproj": true,
    "pkl": true,
    "sql": true,
    "swift": true,
    "toml": true,
    "vue": true,
    "xcode-themes": true,
  },

  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },

  "buffer_font_family": "Liga SFMono Nerd Font",
  "buffer_font_size": 11,
  "completion_menu_item_kind": "symbol",
  "diff_view_style": "unified",

  "git_panel": {
    "default_width": 240,
    "tree_view": true,
  },

  "preferred_line_length": 120,
  "relative_line_numbers": "enabled",

  "tab_bar": {
    "show_nav_history_buttons": false,
  },

  "tabs": {
    "close_position": "left",
    "file_icons": true,
    "git_status": true,
  },

  "theme": {
    "dark": "Xcode Default Darker",
    "light": "Xcode Default Light",
    "mode": "dark",
  },

  "title_bar": {
    "show_sign_in": false,
    "show_user_picture": false,
  },

  "ui_font_family": "SF Pro Display",
  "ui_font_size": 12,

  "vim": {
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "never",
  },

  "vim_mode": true,

  "which_key": {
    "delay_ms": 300,
    "enabled": true,
  },
}
