{
  "agent": {
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "model": "gpt-5.5",
      "provider": "openai-subscribed",
    },
  },
  "agent_servers": {
    "claude-acp": {
      "default_config_options": {
        "mode": "auto"
      },
      "type": "registry",
    },
    "hermes-agent": {
      "type": "custom",
      "command": "hermes",
      "args": ["acp"],
    },
  },
  "auto_install_extensions": {
    "comment": true,
    "git-firefly": true,
    "html": true,
    "make": true,
    "markdown-oxide": true,
    "package-swift-lsp": true,
    "pbxproj": true,
    "ruby": true,
    "swift": true,
    "toml": true,
    "vue": true,
    "xcode-themes": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "buffer_font_family": "Liga SFMono Nerd Font",
  "buffer_font_size": 11,
  "completion_menu_item_kind": "symbol",
  "diff_view_style": "unified",
  "git_panel": {
    "default_width": 240,
  },
  "languages": {
    "Markdown": {
      "soft_wrap": "bounded",
    },
    "Ruby": {
      "language_servers": ["!solargraph"],
    },
  },
  "relative_line_numbers": "enabled",
  "tab_bar": {
    "show_nav_history_buttons": false,
  },
  "tabs": {
    "close_position": "left",
    "file_icons": true,
    "git_status": true,
  },
  "theme": {
    "dark": "Xcode Default Dark",
    "light": "Xcode Default Light",
    "mode": "system",
  },
  "title_bar": {
    "show_sign_in": false,
  },
  "ui_font_family": "SF Pro Display",
  "ui_font_size": 12,
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "never",
  },
  "vim_mode": true,
}
