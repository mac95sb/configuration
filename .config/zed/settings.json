{
  "agent": {
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "model": "gpt-5.5",
      "provider": "openai-subscribed",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "auto_install_extensions": {
    "comment": true,
    "git-firefly": true,
    "make": true,
    "ruby": true,
    "swift": true,
    "vue": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "buffer_font_family": "Liga SFMono Nerd Font",
  "buffer_font_size": 11,
  "completion_menu_item_kind": "symbol",
  "diff_view_style": "unified",
  "git_panel": {
    "default_width": 240,
  },
  "languages": {
    "Markdown": {
      "soft_wrap": "bounded",
    },
  },
  "relative_line_numbers": "enabled",
  "tab_bar": {
    "show_nav_history_buttons": false,
  },
  "tabs": {
    "close_position": "left",
    "file_icons": true,
    "git_status": true,
  },
  "ui_font_family": "SF Pro",
  "ui_font_size": 12,
  "theme": {
    "mode": "system",
    "dark": "Everforest Dark Hard (regular)",
    "light": "Everforest Light Hard (regular)",
  },
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "never",
  },
  "vim_mode": true,
}
