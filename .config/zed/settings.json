{
  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "mode": "agent",
      },
      "type": "registry",
    },
  },
  "auto_install_extensions": {
    "comment": true,
    "everforest": true,
    "git-firefly": true,
    "html": true,
    "make": true,
    "markdown-oxide": true,
    "package-swift-lsp": true,
    "pbxproj": true,
    "pkl": true,
    "swift": true,
    "toml": true,
    "vue": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "buffer_font_family": "Liga SFMono Nerd Font",
  "buffer_font_size": 11,
  "completion_menu_item_kind": "symbol",
  "diff_view_style": "unified",
  "git_panel": {
    "default_width": 240,
    "tree_view": true,
  },
  "preferred_line_length": 120,
  "relative_line_numbers": "enabled",
  "tab_bar": {
    "show_nav_history_buttons": false,
  },
  "tabs": {
    "close_position": "left",
    "file_icons": true,
    "git_status": true,
  },
  "theme": {
    "dark": "Everforest Dark Hard (blur)",
    "light": "Everforest Light Hard (blur)",
    "mode": "dark",
  },
  "theme_overrides": {
    "Everforest Dark Hard (blur)": {
      "ghost_element.background": "#00000000",
      "ghost_element.active": "#36413b",
      "ghost_element.hover": "#36413b",
      "ghost_element.selected": "#36413b",
    },
    "Everforest Light Hard (blur)": {
      "ghost_element.background": "#00000000",
    },
  },
  "title_bar": {
    "show_sign_in": false,
    "show_user_picture": false,
  },
  "ui_font_family": "SF Pro Display",
  "ui_font_size": 12,
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "never",
  },
  "vim_mode": true,
  "which_key": {
    "delay_ms": 300,
    "enabled": true,
  },
}
