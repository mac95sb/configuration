[branch]
	sort = -committerdate

[commit]
	gpgsign = true

[core]
	pager = less -FRX

[fetch]
	prune = true

[gpg]
	format = ssh

[init]
	defaultBranch = main

[merge]
	conflictstyle = zdiff3

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[rerere]
	enabled = true

[tag]
	gpgsign = true

[user]
	email = contact@maclong.dev
	name = Mac
	signingkey = ~/.ssh/id_ed25519
