[user]
	name = Mac
	email = contact@maclong.dev
	signingkey = ~/.ssh/id_ed25519

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[fetch]
	prune = true

[core]
	editor = nvim
	pager = less -FRX

[gpg]
	format = ssh

[commit]
	gpgsign = true

[tag]
	gpgsign = true

[branch]
	sort = -committerdate

[merge]
	conflictstyle = zdiff3

[rerere]
	enabled = true
