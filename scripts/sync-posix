#!/usr/bin/env sh
set -eu

if [ "${CONFIGURATION_SYNC_POSIX:-}" = "1" ]; then
  exit 0
fi

repo_root=$(git rev-parse --show-toplevel)
current_branch=$(git -C "$repo_root" branch --show-current 2>/dev/null || true)
if [ "$current_branch" = "posix" ]; then
  exit 0
fi

git_clean_env() (
  unset GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE GIT_PREFIX
  git "$@"
)

worktree="${CONFIGURATION_POSIX_WORKTREE:-${TMPDIR:-/tmp}/configuration-posix-worktree}"

if git_clean_env -C "$repo_root" show-ref --verify --quiet refs/heads/posix; then
  if [ ! -e "$worktree/.git" ]; then
    git_clean_env -C "$repo_root" worktree add "$worktree" posix
  fi
else
  git_clean_env -C "$repo_root" worktree add --detach "$worktree" HEAD
  git_clean_env -C "$worktree" checkout --orphan posix
fi

if [ "$(git_clean_env -C "$worktree" branch --show-current 2>/dev/null || true)" != "posix" ]; then
  git_clean_env -C "$worktree" checkout posix
fi

git_clean_env -C "$worktree" rm -r --ignore-unmatch . >/dev/null 2>&1 || true
find "$worktree" -mindepth 1 -maxdepth 1 ! -name .git -exec rm -rf {} +

copy_home_path() {
  relative_path=$1
  source_path="$HOME/$relative_path"
  target_path="$worktree/$relative_path"

  if [ ! -e "$source_path" ] && [ ! -L "$source_path" ]; then
    return 0
  fi

  mkdir -p "$(dirname "$target_path")"
  if [ -d "$source_path" ]; then
    cp -R -L "$source_path" "$target_path"
  else
    cp -L "$source_path" "$target_path"
  fi
}

copy_home_path ".zprofile"
copy_home_path ".zshenv"
copy_home_path ".zshrc"
copy_home_path ".config/ghostty/config"
copy_home_path ".config/tmux/tmux.conf"
copy_home_path ".config/git/config"
copy_home_path ".config/git/allowed_signers"
copy_home_path ".config/git/ignore"
copy_home_path ".config/gh/config.yml"

nix eval --raw "$repo_root#darwinConfigurations.mac.config.homebrew.brewfile" > "$worktree/Brewfile"

cat >> "$worktree/Brewfile" <<'EOF'

# POSIX fallbacks for apps and CLI tools managed by Nix/Home Manager in the
# main branch. Keep these explicit: Nix package names do not always map cleanly
# to Homebrew formula or cask names.
brew "gh"
brew "git"
brew "neovim"
brew "tmux"
cask "ghostty"
EOF

cat > "$worktree/README.md" <<'EOF'
# POSIX fallback

This branch is auto-generated from the Nix-managed macOS configuration for
machines where Nix is unavailable.

## Quick Start

```sh
# Install Homebrew
/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

# Clone and switch to this branch
mkdir -p ~/Developer
git clone -b posix https://github.com/mac95sb/configuration ~/Developer/configuration
cd ~/Developer/configuration

# Install packages
brew bundle

# Symlink dotfiles
mkdir -p ~/.config/ghostty ~/.config/tmux ~/.config/git ~/.config/gh
ln -sf ~/Developer/configuration/.zprofile ~/.zprofile
ln -sf ~/Developer/configuration/.zshenv ~/.zshenv
ln -sf ~/Developer/configuration/.zshrc ~/.zshrc
ln -sf ~/Developer/configuration/.config/ghostty/config ~/.config/ghostty/config
ln -sf ~/Developer/configuration/.config/tmux/tmux.conf ~/.config/tmux/tmux.conf
ln -sf ~/Developer/configuration/.config/git/config ~/.config/git/config
ln -sf ~/Developer/configuration/.config/git/allowed_signers ~/.config/git/allowed_signers
ln -sf ~/Developer/configuration/.config/git/ignore ~/.config/git/ignore
ln -sf ~/Developer/configuration/.config/gh/config.yml ~/.config/gh/config.yml

# SSH key
ssh-keygen -t ed25519 -C "contact@maclong.dev"
gh auth login --hostname github.com --git-protocol ssh --scopes "repo,read:org,gist"
gh ssh-key add "$HOME/.ssh/id_ed25519.pub" --type authentication
gh ssh-key add "$HOME/.ssh/id_ed25519.pub" --type signing
```
EOF

git_clean_env -C "$worktree" add -A
if git_clean_env -C "$worktree" diff --cached --quiet; then
  exit 0
fi

source_head=$(git_clean_env -C "$repo_root" rev-parse --short HEAD 2>/dev/null || echo "unknown")
CONFIGURATION_SYNC_POSIX=1 git_clean_env -C "$worktree" commit --no-verify -m "Sync POSIX fallback from $source_head"
git_clean_env -C "$repo_root" push origin posix 2>/dev/null || true
